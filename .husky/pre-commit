#!/bin/sh

# Stamp scripts with the current HEAD short rev (parent of the new commit)
REV=$(git rev-parse --short HEAD)

for script in scripts/*.ps1; do
  if grep -q 'Script:Revision' "$script"; then
    sed -i '' "s/\$Script:Revision = \".*\"/\$Script:Revision = \"$REV\"/" "$script"
    git add "$script"
  fi
done
