# Google Workspace (service account with domain-wide delegation)
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account.json
GOOGLE_ADMIN_EMAIL=admin@ameriglide.com

# Amberjack DB
AMBERJACK_DATABASE_URL=postgresql://aj:PASSWORD@host:25060/aj?sslmode=require

# Phenix DB
PHENIX_DATABASE_URL=postgresql://phenix:PASSWORD@host:25060/phenix?sslmode=require

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WORKSPACE_SID=WS...
TWILIO_CREDENTIAL_LIST_SID=CL...
TWILIO_TWIML_APP_SID=AP...

# AES-256 encryption key (base64-encoded, 32 bytes decoded)
AES_KEY=

# Tailscale (existing, used by bin/copy)
TAILSCALE_AUTH_KEY=

# Zoiper Pro license (used by setup-zoiper.ps1 and install-apps.ps1)
ZOIPER_USERNAME=
ZOIPER_PASSWORD=

# Office Wi-Fi — passed to deploy-gcpw.ps1 so the all-user profile is in place
# pre-login on fresh Win11 boxes (required for GCPW to reach Google at sign-in).
WIFI_SSID=
WIFI_PASSWORD=

# Google Workspace domain for the tenant this checkout serves
# (ameriglide.com, inetalliance.net, etc.). Used by bin/copy, bin/onboard,
# bin/reset-user to derive user@<domain> emails and the GCPW SAM-account
# suffix (<localpart>_<domain-no-tld>). Passed through to install-apps.ps1
# for Chrome site-permission allowlists.
DOMAIN=ameriglide.com

# Brand label used for company-branded paths created by install-apps.ps1:
# C:\ProgramData\<BRAND> for the chrome/RDP launcher scripts, and
# $env:LOCALAPPDATA\.<brand-lower>-2sv-prompted for the per-user 2SV flag.
# Also used as the display name for the storefront bookmark on the Chrome
# bookmark bar. Stays in user-visible places (login auto-start, desktop
# shortcut, bookmark) so the UX feels native to whichever company the
# machine belongs to. Avoid spaces — directory name uses this verbatim.
BRAND=AmeriGlide

# Marketing/storefront URL for the company bookmark on the Chrome bar.
# AmeriGlide -> https://www.ameriglide.com, iai -> https://www.usmedicalsupplies.com.
MARKETING_URL=https://www.ameriglide.com

# Twilio PSTN subdomain used in agent SIP URIs (e.g. user@<tenant>.pstn.twilio.com).
# Only relevant if bin/onboard is wiring up Twilio for this tenant.
TWILIO_PSTN_DOMAIN=ameriglide.pstn.twilio.com
