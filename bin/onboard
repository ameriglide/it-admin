#!/usr/bin/env bun

import "../src/lib/load-env"; // must be first: loads repo-root .env regardless of cwd
import { parseArgs } from "util";
import { run } from "../src/onboard/run";
import { confirm, input } from "../src/onboard/lib/prompt";
import { walkWorkstationSetup } from "../src/onboard/workstation";
import type { Context } from "../src/onboard/types";

const { values } = parseArgs({
  args: Bun.argv.slice(2),
  options: {
    first: { type: "string" },
    last: { type: "string" },
    email: { type: "string" },
    skip: { type: "string" },
    "direct-line": { type: "boolean", default: false },
    channel: { type: "string" },
  },
  strict: true,
});

const directLine = Bun.argv.includes("--direct-line") ? true : undefined;
const skip = values.skip
  ? values.skip.split(",").map((s) => s.trim().toLowerCase())
  : [];

const firstName = values.first ?? (await input("First name"));
const lastName = values.last ?? (await input("Last name"));

if (!firstName || !lastName) {
  console.error("First and last name are required.");
  process.exit(1);
}

const domain = process.env.DOMAIN ?? "ameriglide.com";
const email =
  values.email ??
  `${firstName.toLowerCase()}.${lastName.toLowerCase()}@${domain}`;

console.log(`\nOnboarding ${firstName} ${lastName} (${email})\n`);

const ctx: Context = {
  firstName,
  lastName,
  email,
  directLine,
  phenixChannel: values.channel,
};

await run(ctx, skip);

// Continue into the workstation setup (the steps you'd paste into the new
// machine), reusing the context we just built. Optional — skip if no machine
// is in front of you yet.
if (await confirm("Set up the workstation now?")) {
  await walkWorkstationSetup(ctx);
}
