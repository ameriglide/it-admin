#!/usr/bin/env bun

import { parseArgs } from "util";
import { getPhenix, closeAll } from "../src/onboard/lib/db";
import { decrypt } from "../src/onboard/lib/crypto";

const { values } = parseArgs({
  args: Bun.argv.slice(2),
  options: {
    email: { type: "string" },
  },
  strict: true,
});

if (!values.email) {
  console.error("Usage: bin/sip-password --email user@example.com");
  process.exit(1);
}

const aesKeyB64 = process.env.AES_KEY;
if (!aesKeyB64) throw new Error("AES_KEY not set");
const aesKey = Buffer.from(aesKeyB64, "base64");

const sql = getPhenix();

try {
  const [row] = await sql`
    SELECT firstname, lastname, sipsecret, sipuri FROM agent WHERE email = ${values.email}
  `;

  if (!row) {
    console.error(`No agent found with email ${values.email}`);
    process.exit(1);
  }

  if (!row.sipsecret) {
    console.error(`Agent ${row.firstname} ${row.lastname} has no SIP secret stored`);
    process.exit(1);
  }

  const ciphertext = Buffer.from(row.sipsecret, "hex");
  const password = decrypt(ciphertext, aesKey);
  const sipUser = `${row.firstname.toLowerCase()}.${row.lastname.toLowerCase()}`;

  console.log(`Agent:    ${row.firstname} ${row.lastname}`);
  console.log(`SIP User: ${sipUser}`);
  console.log(`SIP Pass: ${password}`);
  console.log(`SIP URI:  ${row.sipuri ?? "not set"}`);
} finally {
  await closeAll();
}
