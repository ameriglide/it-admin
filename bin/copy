#!/usr/bin/env bash
#
# Interactive clipboard helper for workstation setup.
# Copies one-liners and secrets to the clipboard so you can paste them
# into a remote machine's PowerShell prompt.
#
# Usage: ./bin/copy
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Load .env if present
if [[ -f "$SCRIPT_DIR/.env" ]]; then
  # shellcheck disable=SC2046
  export $(grep -v '^#' "$SCRIPT_DIR/.env" | xargs)
fi

# ---------------------------------------------------------------------------
# Menu entries: label → payload (computed lazily via functions)
# ---------------------------------------------------------------------------

new_machine() {
  local ssid="${WIFI_SSID:-}"
  local pass="${WIFI_PASSWORD:-}"
  local cmd='Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/deploy-gcpw.ps1 -OutFile $env:TEMP\deploy-gcpw.ps1; & $env:TEMP\deploy-gcpw.ps1 -NewMachine -Domain ameriglide.com'
  if [[ -n "$ssid" && -n "$pass" ]]; then
    cmd="$cmd -WifiSsid \"$ssid\" -WifiPassword \"$pass\""
  else
    echo >&2 "  ⚠  WIFI_SSID/WIFI_PASSWORD not set in .env — Wi-Fi profile won't be pre-installed as all-user (sign-in screen may have no network)"
  fi
  echo "$cmd"
}

install_apps() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env — using placeholder"
    key="<paste-key-here>"
  fi
  local zuser="${ZOIPER_USERNAME:-}"
  local zpass="${ZOIPER_PASSWORD:-}"
  local cmd="Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/install-apps.ps1 -OutFile \$env:TEMP\\install-apps.ps1; & \$env:TEMP\\install-apps.ps1 -TailscaleAuthKey \"$key\""
  if [[ -n "$zuser" && -n "$zpass" ]]; then
    cmd="$cmd -ZoiperUsername \"$zuser\" -ZoiperPassword \"$zpass\""
  else
    echo >&2 "  ⚠  ZOIPER_USERNAME/ZOIPER_PASSWORD not set in .env — Zoiper activation will be skipped"
  fi
  echo "$cmd"
}

reset_gcpw_user() {
  local user
  user=$(gum input --placeholder "jim.soffe" --header "Reset GCPW state for which user? (username only)" </dev/tty)
  [[ -z "$user" ]] && return 1

  # bin/reset-user does the Mac-side ops (password reset + OU move) and
  # emits the Windows-side cleanup PowerShell to stdout for the clipboard.
  "$SCRIPT_DIR/bin/reset-user" --user "$user"
}

migration_phase1() {
  local user
  user=$(gum input --placeholder "Google username (e.g. jsmith)" --header "Migration: enter employee username" </dev/tty)
  [[ -z "$user" ]] && return 1
  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/deploy-gcpw.ps1 -OutFile \$env:TEMP\\deploy-gcpw.ps1; & \$env:TEMP\\deploy-gcpw.ps1 -GoogleEmail ${user}@ameriglide.com -Domain ameriglide.com -WindowsUsername ${user} -Phase 1"
}

migration_phase2() {
  echo '& $env:TEMP\deploy-gcpw.ps1 -Phase 2'
}

zoiper_setup() {
  local email
  email=$(gum input --placeholder "user@ameriglide.com" --header "Zoiper: enter employee email" </dev/tty)
  [[ -z "$email" ]] && return 1
  [[ "$email" != *@* ]] && email="${email}@ameriglide.com"

  echo >&2 "  Looking up SIP credentials..."
  local sip_output
  if ! sip_output=$("$SCRIPT_DIR/bin/sip-password" --email "$email" 2>/dev/null); then
    echo >&2 "  ⚠  No SIP credentials found for $email"
    return 1
  fi

  local sip_user sip_pass
  sip_user=$(echo "$sip_output" | sed -n 's/^SIP User: *//p')
  sip_pass=$(echo "$sip_output" | sed -n 's/^SIP Pass: *//p')

  if [[ -z "$sip_user" || -z "$sip_pass" ]]; then
    echo >&2 "  ⚠  Could not parse SIP credentials"
    return 1
  fi

  echo >&2 "  ✓ Found SIP user: $sip_user"

  # GCPW creates SAM accounts named <localpart>_<domain-no-tld>, so the
  # profile path is C:\Users\jim.soffe_ameriglide (not C:\Users\jim.soffe).
  # Prefill with the SAM-style name to match GCPW-provisioned profiles.
  local win_user
  win_user=$(gum input --value "${sip_user}_ameriglide" --header "Windows username (blank = Default profile only)" </dev/tty) || true

  local zuser="${ZOIPER_USERNAME:-}"
  local zpass="${ZOIPER_PASSWORD:-}"
  local cmd="Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/setup-zoiper.ps1 -OutFile \$env:TEMP\\setup-zoiper.ps1; & \$env:TEMP\\setup-zoiper.ps1 -SipUser \"$sip_user\" -SipPassword \"$sip_pass\""
  if [[ -n "$zuser" && -n "$zpass" ]]; then
    cmd="$cmd -ZoiperUsername \"$zuser\" -ZoiperPassword \"$zpass\""
  else
    echo >&2 "  ⚠  ZOIPER_USERNAME/ZOIPER_PASSWORD not set — activation will be skipped"
  fi
  if [[ -n "$win_user" ]]; then
    cmd="$cmd -TargetUser \"$win_user\""
  fi
  echo "$cmd"
}

install_tailscale() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env — using placeholder"
    key="<paste-key-here>"
  fi
  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/install-apps.ps1 -OutFile \$env:TEMP\\install-apps.ps1; & \$env:TEMP\\install-apps.ps1 -TailscaleAuthKey \"$key\" -Only tailscale"
}

tailscale_key() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env"
    return 1
  fi
  echo "tailscale up --login-server https://headscale.mage.net --auth-key $key --unattended --timeout 30s"
}

new_tailscale_key() {
  echo >&2 "  Generating new key via headscale..."
  local key
  key=$(ssh headscale 'docker exec headscale headscale preauthkeys create --user 1 --reusable' 2>/dev/null)
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  Failed to generate key (SSH to headscale failed?)"
    return 1
  fi
  # Update .env
  if grep -q '^TAILSCALE_AUTH_KEY=' "$SCRIPT_DIR/.env" 2>/dev/null; then
    sed -i '' "s|^TAILSCALE_AUTH_KEY=.*|TAILSCALE_AUTH_KEY=$key|" "$SCRIPT_DIR/.env"
  else
    echo "TAILSCALE_AUTH_KEY=$key" >> "$SCRIPT_DIR/.env"
  fi
  # No effect on parent (we run in $(...) subshell), but documents intent.
  # Visibility to other menu options happens via the .env re-source in the loop.
  export TAILSCALE_AUTH_KEY="$key"
  echo >&2 "  Updated .env with new key (expires in 24h)"
  echo "$key"
}

# ---------------------------------------------------------------------------
# Menu
# ---------------------------------------------------------------------------

LABELS=(
  "GCPW — new machine setup"
  "GCPW — reset user state (re-test first login)..."
  "Install apps (with Tailscale key)"
  "Tailscale — install + join (only)"
  "Zoiper — install + configure..."
  "JumpCloud to GCPW — phase 1..."
  "JumpCloud to GCPW — phase 2"
  "Tailscale — join network (from .env)"
  "Generate new Tailscale key (SSH → headscale)..."
)

# Map label → function
dispatch() {
  case "$1" in
    "GCPW — new machine setup")                 new_machine ;;
    "GCPW — reset user state (re-test first login)...") reset_gcpw_user ;;
    "Install apps (with Tailscale key)")        install_apps ;;
    "Tailscale — install + join (only)")        install_tailscale ;;
    "Zoiper — install + configure...")             zoiper_setup ;;
    "JumpCloud to GCPW — phase 1...")              migration_phase1 ;;
    "JumpCloud to GCPW — phase 2")               migration_phase2 ;;
    "Tailscale — join network (from .env)")            tailscale_key ;;
    "Generate new Tailscale key (SSH → headscale)...") new_tailscale_key ;;
    *) return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# Loop
# ---------------------------------------------------------------------------

PS3="  Pick an option (q to quit): "
echo
select choice in "${LABELS[@]}"; do
  [[ -z "$choice" ]] && { [[ "$REPLY" == q ]] && break; continue; }

  # Re-source .env each iteration so option-9 (key rotation) is visible to option 8.
  if [[ -f "$SCRIPT_DIR/.env" ]]; then
    # shellcheck disable=SC2046
    export $(grep -v '^#' "$SCRIPT_DIR/.env" | xargs)
  fi

  payload=$(dispatch "$choice") || { echo; continue; }

  printf '%s' "$payload" | pbcopy
  gum style --foreground 35 "  ✓ Copied: $choice"
  echo
done
