#!/usr/bin/env bash
#
# Interactive clipboard helper for workstation setup.
# Copies one-liners and secrets to the clipboard so you can paste them
# into a remote machine's PowerShell prompt.
#
# Usage: ./bin/copy
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Load .env if present
if [[ -f "$SCRIPT_DIR/.env" ]]; then
  # shellcheck disable=SC2046
  export $(grep -v '^#' "$SCRIPT_DIR/.env" | xargs)
fi

# Workspace domain — used to build user@<domain> emails in PS one-liners.
: "${DOMAIN:=ameriglide.com}"

# Brand label and storefront URL — passed to install-apps.ps1 to brand the
# ProgramData launcher dir, 2SV flag, and bookmark bar storefront entry.
: "${BRAND:=AmeriGlide}"
: "${MARKETING_URL:=https://www.ameriglide.com}"

# ---------------------------------------------------------------------------
# Menu entries: label → payload (computed lazily via functions)
# ---------------------------------------------------------------------------

new_machine() {
  local ssid="${WIFI_SSID:-}"
  local pass="${WIFI_PASSWORD:-}"
  local cmd="Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/deploy-gcpw.ps1 -OutFile \$env:TEMP\\deploy-gcpw.ps1; & \$env:TEMP\\deploy-gcpw.ps1 -NewMachine -Domain ${DOMAIN}"
  if [[ -n "$ssid" && -n "$pass" ]]; then
    cmd="$cmd -WifiSsid \"$ssid\" -WifiPassword \"$pass\""
  else
    echo >&2 "  ⚠  WIFI_SSID/WIFI_PASSWORD not set in .env — Wi-Fi profile won't be pre-installed as all-user (sign-in screen may have no network)"
  fi
  echo "$cmd"
}

install_apps() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env — using placeholder"
    key="<paste-key-here>"
  fi
  local zuser="${ZOIPER_USERNAME:-}"
  local zpass="${ZOIPER_PASSWORD:-}"
  local cmd="Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/install-apps.ps1 -OutFile \$env:TEMP\\install-apps.ps1; & \$env:TEMP\\install-apps.ps1 -Domain ${DOMAIN} -Brand \"${BRAND}\" -MarketingUrl \"${MARKETING_URL}\" -TailscaleAuthKey \"$key\""
  if [[ -n "$zuser" && -n "$zpass" ]]; then
    cmd="$cmd -ZoiperUsername \"$zuser\" -ZoiperPassword \"$zpass\""
  else
    echo >&2 "  ⚠  ZOIPER_USERNAME/ZOIPER_PASSWORD not set in .env — Zoiper activation will be skipped"
  fi
  echo "$cmd"
}

reset_gcpw_user() {
  local user
  user=$(gum input --placeholder "first.last" --header "Reset GCPW state for which user? (username only — type and press Enter)" </dev/tty)
  [[ -z "$user" ]] && return 1

  # bin/reset-user does the Mac-side ops (password reset + OU move) and
  # emits the Windows-side cleanup PowerShell to stdout for the clipboard.
  "$SCRIPT_DIR/bin/reset-user" --user "$user"
}

migration_phase1() {
  local user
  user=$(gum input --placeholder "Google username (e.g. jsmith)" --header "Migration: enter employee username" </dev/tty)
  [[ -z "$user" ]] && return 1
  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/deploy-gcpw.ps1 -OutFile \$env:TEMP\\deploy-gcpw.ps1; & \$env:TEMP\\deploy-gcpw.ps1 -GoogleEmail ${user}@${DOMAIN} -Domain ${DOMAIN} -WindowsUsername ${user} -Phase 1"
}

migration_phase2() {
  echo '& $env:TEMP\deploy-gcpw.ps1 -Phase 2'
}

zoiper_setup() {
  local email
  email=$(gum input --placeholder "user@${DOMAIN}" --header "Zoiper: enter employee email" </dev/tty)
  [[ -z "$email" ]] && return 1
  [[ "$email" != *@* ]] && email="${email}@${DOMAIN}"

  echo >&2 "  Looking up SIP credentials..."
  local sip_output
  if ! sip_output=$("$SCRIPT_DIR/bin/sip-password" --email "$email" 2>/dev/null); then
    echo >&2 "  ⚠  No SIP credentials found for $email"
    return 1
  fi

  local sip_user sip_pass
  sip_user=$(echo "$sip_output" | sed -n 's/^SIP User: *//p')
  sip_pass=$(echo "$sip_output" | sed -n 's/^SIP Pass: *//p')

  if [[ -z "$sip_user" || -z "$sip_pass" ]]; then
    echo >&2 "  ⚠  Could not parse SIP credentials"
    return 1
  fi

  echo >&2 "  ✓ Found SIP user: $sip_user"

  # GCPW creates SAM accounts named <localpart>_<domain-no-tld>, so the
  # profile path is C:\Users\jim.soffe_ameriglide (not C:\Users\jim.soffe)
  # for ameriglide.com — and ..._inetalliance for inetalliance.net, etc.
  # Prefill with the SAM-style name to match GCPW-provisioned profiles.
  local domain_base="${DOMAIN%%.*}"
  local win_user
  win_user=$(gum input --value "${sip_user}_${domain_base}" --header "Windows username (blank = Default profile only)" </dev/tty) || true

  local zuser="${ZOIPER_USERNAME:-}"
  local zpass="${ZOIPER_PASSWORD:-}"
  local cmd="Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/setup-zoiper.ps1 -OutFile \$env:TEMP\\setup-zoiper.ps1; & \$env:TEMP\\setup-zoiper.ps1 -SipUser \"$sip_user\" -SipPassword \"$sip_pass\""
  if [[ -n "$zuser" && -n "$zpass" ]]; then
    cmd="$cmd -ZoiperUsername \"$zuser\" -ZoiperPassword \"$zpass\""
  else
    echo >&2 "  ⚠  ZOIPER_USERNAME/ZOIPER_PASSWORD not set — activation will be skipped"
  fi
  if [[ -n "$win_user" ]]; then
    cmd="$cmd -TargetUser \"$win_user\""
  fi
  echo "$cmd"
}

sage_amg_onboard() {
  local user
  user=$(gum input --placeholder "first.last" --header "sage-amg onboard: enter username" </dev/tty)
  [[ -z "$user" ]] && return 1

  local pass
  pass=$(gum input --password --header "Password (use the same one set on their Google account)" </dev/tty)
  [[ -z "$pass" ]] && return 1

  # Escape single-quotes for safe embedding inside PS '...' literal.
  local pass_escaped="${pass//\'/\'\'}"

  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/onboard-sage-amg-user.ps1 -OutFile \$env:TEMP\\onboard-sage-amg-user.ps1; & \$env:TEMP\\onboard-sage-amg-user.ps1 -SamName ${user} -Password '${pass_escaped}'"
}

install_tailscale() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env — using placeholder"
    key="<paste-key-here>"
  fi
  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/install-apps.ps1 -OutFile \$env:TEMP\\install-apps.ps1; & \$env:TEMP\\install-apps.ps1 -TailscaleAuthKey \"$key\" -Only tailscale"
}

tailscale_key() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env"
    return 1
  fi
  echo "tailscale up --login-server https://headscale.mage.net --auth-key $key --unattended --timeout 30s"
}

new_tailscale_key() {
  echo >&2 "  Generating new key via headscale..."
  local key
  # 2160h = 90 days, so onboarding keys don't silently expire mid-rollout.
  key=$(ssh headscale 'docker exec headscale headscale preauthkeys create --user 1 --reusable --expiration 2160h' 2>/dev/null)
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  Failed to generate key (SSH to headscale failed?)"
    return 1
  fi
  # Update .env
  if grep -q '^TAILSCALE_AUTH_KEY=' "$SCRIPT_DIR/.env" 2>/dev/null; then
    sed -i '' "s|^TAILSCALE_AUTH_KEY=.*|TAILSCALE_AUTH_KEY=$key|" "$SCRIPT_DIR/.env"
  else
    echo "TAILSCALE_AUTH_KEY=$key" >> "$SCRIPT_DIR/.env"
  fi
  # No effect on parent (we run in $(...) subshell), but documents intent.
  # Visibility to other menu options happens via the .env re-source in the loop.
  export TAILSCALE_AUTH_KEY="$key"
  echo >&2 "  Saved new key to .env (expires in 90 days)"
  echo "$key"
}

# ---------------------------------------------------------------------------
# Guided onboarding walkthrough
# ---------------------------------------------------------------------------
# Walks the technician through the full new-employee + new-machine flow in
# order, copying the right PowerShell one-liner to the clipboard at each
# workstation step. The canonical order also lives in README "Onboarding
# runbook" — keep the two in sync.
#
# [CONFIRM] Best-guess assumptions baked in (fix if wrong):
#   - Steps 2-3 are run by the technician from an ELEVATED PowerShell on the
#     fresh machine (OOBE local account or 'localadmin'), BEFORE the employee
#     ever signs in with Google.
#   - Zoiper (step 5) is run after the employee's first Google sign-in so the
#     config lands in their GCPW-provisioned profile.
_pause() {
  printf '\n'
  # Drain any keystrokes buffered during the previous step (stray Enters, or
  # input left over by gum) so we wait for a FRESH keypress instead of sailing
  # through every step on stale newlines. Portable + set -e safe.
  local _saved
  if _saved=$(stty -g </dev/tty 2>/dev/null); then
    stty -icanon min 0 time 0 </dev/tty 2>/dev/null
    while IFS= read -r -n 1 _ </dev/tty 2>/dev/null; do :; done
    stty "$_saved" </dev/tty 2>/dev/null
  fi
  read -r -p "  Press Enter when this step is done (Ctrl-C to abort)... " _ </dev/tty
  printf '\n'
}

_step() {
  local title="$1"; shift
  gum style --foreground 35 "  $title"
  local line
  for line in "$@"; do printf '    %s\n' "$line"; done
}

_copy_step() {
  local title="$1" payload="$2"; shift 2
  gum style --foreground 35 "  $title"
  local line
  for line in "$@"; do printf '    %s\n' "$line"; done
  printf '%s' "$payload" | pbcopy
  gum style --foreground 35 "    ✓ One-liner copied — paste into an elevated PowerShell on the workstation."
  _pause
}

onboard_runbook() {
  local first last
  first=$(gum input --placeholder "First" --header "Guided onboarding: employee first name" </dev/tty) || return 0
  last=$(gum input --placeholder "Last" --header "Guided onboarding: employee last name" </dev/tty) || return 0
  [[ -z "$first" || -z "$last" ]] && return 0

  gum style --border rounded --padding "0 1" --foreground 35 \
    "Onboarding: $first $last" \
    "Work top to bottom. Workstation steps copy a one-liner to your clipboard;" \
    "paste each into an ELEVATED PowerShell on the new machine."

  local onboard_cmd="bin/onboard --first \"$first\" --last \"$last\""
  _step "1/6  Mac: provision accounts" \
    "In the it-admin repo on your Mac (NOT the workstation), run:" \
    "    $onboard_cmd" \
    "Creates Google, Amberjack, Phenix, Twilio + SIP, and the Zoiper config." \
    "Idempotent — re-run to resume. Let it finish before continuing."
  printf '%s' "$onboard_cmd" | pbcopy
  gum style --foreground 35 "    ✓ Command copied — paste into your Mac terminal in the it-admin repo."
  _pause

  _copy_step "2/6  Workstation (elevated PS): GCPW new-machine setup [only if needed]" "$(new_machine)" \
    "ONLY for a brand-new machine that doesn't already have GCPW. Most reused/" \
    "imaged machines already do — skip this step and just paste-and-continue." \
    "Installs GCPW, creates the 'localadmin' break-glass admin, and sets the" \
    "Google sign-in domain. Run as a local admin during Windows OOBE."

  _copy_step "3/6  Workstation (elevated PS): install apps + Tailscale" "$(install_apps)" \
    "Installs the standard app set and joins the Tailscale network."

  gum style --foreground 35 "  4/6  Workstation (elevated PS): Zoiper into the Default profile"
  printf '    %s\n' \
    "Do this BEFORE the employee's first login so it's already there when they" \
    "sign in. Leave the Windows username BLANK to write to the Default profile —" \
    "their GCPW profile doesn't exist until they sign in for the first time."
  local zoiper_cmd
  if zoiper_cmd=$(zoiper_setup); then
    printf '%s' "$zoiper_cmd" | pbcopy
    gum style --foreground 35 "    ✓ Zoiper one-liner copied — paste into the elevated PowerShell."
  else
    gum style --foreground 214 "    ⚠  Skipped Zoiper (no SIP creds yet?) — use the Zoiper menu entry later."
  fi
  _pause

  _step "5/6  Verify the account was created properly" \
    "Confirm bin/onboard finished cleanly and $first looks right in the Google" \
    "Admin Console (and the device shows under Devices). If you did a test" \
    "sign-in on the machine, that profile gets cleaned up by the next step."
  _pause

  local reset_user
  reset_user="$(printf '%s.%s' "$first" "$last" | tr '[:upper:]' '[:lower:]')"
  gum style --foreground 35 "  6/6  Final: re-arm a clean first-login (reset GCPW/Windows state)"
  printf '    %s\n' \
    "Runs the Mac-side reset for $reset_user now (re-arms the forced password" \
    "change + OU move) and copies a Windows cleanup one-liner to paste into" \
    "elevated PS on the machine. After this, the employee signs in for a" \
    "pristine first-login."
  local reset_cmd
  if reset_cmd=$("$SCRIPT_DIR/bin/reset-user" --user "$reset_user"); then
    printf '%s' "$reset_cmd" | pbcopy
    gum style --foreground 35 "    ✓ Windows cleanup one-liner copied — paste into the elevated PowerShell."
  else
    gum style --foreground 214 "    ⚠  Reset failed for $reset_user — run the reset menu entry manually."
  fi
  _pause

  gum style --border rounded --padding "0 1" --foreground 35 \
    "Done — $first $last is ready." \
    "Hand off the machine; the employee signs in for a clean first-login."
}

# ---------------------------------------------------------------------------
# Menu
# ---------------------------------------------------------------------------

LABELS=(
  "▶ Guided onboarding (walk me through it)..."
  "── Routine: employee workstation setup ──"
  "Install apps (with Tailscale key)"
  "GCPW — reset user state (re-test first login)..."
  "── Migration / one-offs ──"
  "GCPW — new machine setup"
  "Zoiper — install + configure..."
  "Tailscale — install + join (only)"
  "Tailscale — join network (from .env)"
  "Generate new Tailscale key (SSH → headscale, saves to .env)..."
  "sage-amg — onboard new user..."
  "JumpCloud to GCPW — phase 1..."
  "JumpCloud to GCPW — phase 2"
)

# Map label → function
dispatch() {
  case "$1" in
    "GCPW — new machine setup")                 new_machine ;;
    "GCPW — reset user state (re-test first login)...") reset_gcpw_user ;;
    "Install apps (with Tailscale key)")        install_apps ;;
    "Tailscale — install + join (only)")        install_tailscale ;;
    "Zoiper — install + configure...")             zoiper_setup ;;
    "sage-amg — onboard new user...")           sage_amg_onboard ;;
    "JumpCloud to GCPW — phase 1...")              migration_phase1 ;;
    "JumpCloud to GCPW — phase 2")               migration_phase2 ;;
    "Tailscale — join network (from .env)")            tailscale_key ;;
    "Generate new Tailscale key (SSH → headscale, saves to .env)...") new_tailscale_key ;;
    *) return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# Loop
# ---------------------------------------------------------------------------

PS3="  Pick an option (q to quit): "
echo
select choice in "${LABELS[@]}"; do
  [[ -z "$choice" ]] && { [[ "$REPLY" == q ]] && break; continue; }

  # Re-source .env each iteration so option-9 (key rotation) is visible to option 8.
  if [[ -f "$SCRIPT_DIR/.env" ]]; then
    # shellcheck disable=SC2046
    export $(grep -v '^#' "$SCRIPT_DIR/.env" | xargs)
  fi

  # Separator/header rows are not actions.
  case "$choice" in
    "── "*) echo; continue ;;
  esac

  # Guided onboarding runs interactively and manages its own clipboard copies.
  if [[ "$choice" == "▶ Guided onboarding"* ]]; then
    onboard_runbook
    echo
    continue
  fi

  payload=$(dispatch "$choice") || { echo; continue; }

  printf '%s' "$payload" | pbcopy
  gum style --foreground 35 "  ✓ Copied: $choice"
  echo
done
