#!/usr/bin/env bash
#
# Interactive clipboard helper for workstation setup.
# Copies one-liners and secrets to the clipboard so you can paste them
# into a remote machine's PowerShell prompt.
#
# Usage: ./bin/copy
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Load .env (set -a auto-exports). .env is sourced, so every value must be
# quoted (e.g. KEY="value with spaces") to be safe with spaces/special chars.
load_env() {
  [[ -f "$SCRIPT_DIR/.env" ]] || return 0
  set -a
  # shellcheck disable=SC1091
  . "$SCRIPT_DIR/.env"
  set +a
}
load_env

# Workspace domain — used to build user@<domain> emails in PS one-liners.
: "${DOMAIN:=ameriglide.com}"

# Brand label and storefront URL — passed to setup-workstation.ps1 to brand
# the ProgramData launcher dir, 2SV flag, and bookmark bar storefront entry.
: "${BRAND:=AmeriGlide}"
: "${MARKETING_URL:=https://www.ameriglide.com}"

# ---------------------------------------------------------------------------
# Menu entries: label → payload (computed lazily via functions)
# ---------------------------------------------------------------------------

new_machine() {
  local ssid="${WIFI_SSID:-}"
  local pass="${WIFI_PASSWORD:-}"
  local cmd="Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/deploy-gcpw.ps1 -OutFile \$env:TEMP\\deploy-gcpw.ps1; & \$env:TEMP\\deploy-gcpw.ps1 -NewMachine -Domain ${DOMAIN}"
  if [[ -n "$ssid" && -n "$pass" ]]; then
    cmd="$cmd -WifiSsid \"$ssid\" -WifiPassword \"$pass\""
  else
    echo >&2 "  ⚠  WIFI_SSID/WIFI_PASSWORD not set in .env — Wi-Fi profile won't be pre-installed as all-user (sign-in screen may have no network)"
  fi
  echo "$cmd"
}

install_apps() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env — using placeholder"
    key="<paste-key-here>"
  fi
  local zuser="${ZOIPER_USERNAME:-}"
  local zpass="${ZOIPER_PASSWORD:-}"
  local cmd="Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/setup-workstation.ps1 -OutFile \$env:TEMP\\setup-workstation.ps1; & \$env:TEMP\\setup-workstation.ps1 -Domain ${DOMAIN} -Brand \"${BRAND}\" -MarketingUrl \"${MARKETING_URL}\" -TailscaleAuthKey \"$key\" -HeadscaleUrl \"${HEADSCALE_URL:-}\" -Anchors ${TAILNET_ANCHORS_WORKSTATION:-}"
  if [[ -n "$zuser" && -n "$zpass" ]]; then
    cmd="$cmd -ZoiperUsername \"$zuser\" -ZoiperPassword \"$zpass\""
  else
    echo >&2 "  ⚠  ZOIPER_USERNAME/ZOIPER_PASSWORD not set in .env — Zoiper activation will be skipped"
  fi
  echo "$cmd"
}

reset_gcpw_user() {
  local user
  user=$(gum input --placeholder "first.last" --header "Reset GCPW state for which user? (username only — type and press Enter)" </dev/tty)
  [[ -z "$user" ]] && return 1

  # bin/reset-user does the Mac-side ops (password reset + OU move) and
  # emits the Windows-side cleanup PowerShell to stdout for the clipboard.
  "$SCRIPT_DIR/bin/reset-user" --user "$user"
}

migration_phase1() {
  local user
  user=$(gum input --placeholder "Google username (e.g. jsmith)" --header "Migration: enter employee username" </dev/tty)
  [[ -z "$user" ]] && return 1
  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/deploy-gcpw.ps1 -OutFile \$env:TEMP\\deploy-gcpw.ps1; & \$env:TEMP\\deploy-gcpw.ps1 -GoogleEmail ${user}@${DOMAIN} -Domain ${DOMAIN} -WindowsUsername ${user} -Phase 1"
}

migration_phase2() {
  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/deploy-gcpw.ps1 -OutFile \$env:TEMP\\deploy-gcpw.ps1; & \$env:TEMP\\deploy-gcpw.ps1 -Phase 2"
}

zoiper_setup() {
  local email
  email=$(gum input --placeholder "user@${DOMAIN}" --header "Zoiper: enter employee email" </dev/tty)
  [[ -z "$email" ]] && return 1
  [[ "$email" != *@* ]] && email="${email}@${DOMAIN}"

  echo >&2 "  Looking up SIP credentials..."
  local sip_output
  if ! sip_output=$("$SCRIPT_DIR/bin/sip-password" --email "$email" 2>/dev/null); then
    echo >&2 "  ⚠  No SIP credentials found for $email"
    return 1
  fi

  local sip_user sip_pass
  sip_user=$(echo "$sip_output" | sed -n 's/^SIP User: *//p')
  sip_pass=$(echo "$sip_output" | sed -n 's/^SIP Pass: *//p')

  if [[ -z "$sip_user" || -z "$sip_pass" ]]; then
    echo >&2 "  ⚠  Could not parse SIP credentials"
    return 1
  fi

  echo >&2 "  ✓ Found SIP user: $sip_user"

  # GCPW creates SAM accounts named <localpart>_<domain-no-tld>, so the
  # profile path is C:\Users\jim.soffe_ameriglide (not C:\Users\jim.soffe)
  # for ameriglide.com — and ..._inetalliance for inetalliance.net, etc.
  # Prefill with the SAM-style name to match GCPW-provisioned profiles.
  local domain_base="${DOMAIN%%.*}"
  local win_user
  win_user=$(gum input --value "${sip_user}_${domain_base}" --header "Windows username (blank = Default profile only)" </dev/tty) || true

  local zuser="${ZOIPER_USERNAME:-}"
  local zpass="${ZOIPER_PASSWORD:-}"
  local cmd="Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/setup-zoiper.ps1 -OutFile \$env:TEMP\\setup-zoiper.ps1; & \$env:TEMP\\setup-zoiper.ps1 -SipUser \"$sip_user\" -SipPassword \"$sip_pass\""
  if [[ -n "$zuser" && -n "$zpass" ]]; then
    cmd="$cmd -ZoiperUsername \"$zuser\" -ZoiperPassword \"$zpass\""
  else
    echo >&2 "  ⚠  ZOIPER_USERNAME/ZOIPER_PASSWORD not set — activation will be skipped"
  fi
  if [[ -n "$win_user" ]]; then
    cmd="$cmd -TargetUser \"$win_user\""
  fi
  echo "$cmd"
}

sage_amg_onboard() {
  local user
  user=$(gum input --placeholder "first.last" --header "sage-amg onboard: enter username" </dev/tty)
  [[ -z "$user" ]] && return 1

  local pass
  pass=$(gum input --password --header "Password (use the same one set on their Google account)" </dev/tty)
  [[ -z "$pass" ]] && return 1

  # Escape single-quotes for safe embedding inside PS '...' literal.
  local pass_escaped="${pass//\'/\'\'}"

  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/onboard-sage-amg-user.ps1 -OutFile \$env:TEMP\\onboard-sage-amg-user.ps1; & \$env:TEMP\\onboard-sage-amg-user.ps1 -SamName ${user} -Password '${pass_escaped}' -HeadscaleUrl \"${HEADSCALE_URL:-}\""
}

install_tailscale() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env — using placeholder"
    key="<paste-key-here>"
  fi
  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/setup-workstation.ps1 -OutFile \$env:TEMP\\setup-workstation.ps1; & \$env:TEMP\\setup-workstation.ps1 -TailscaleAuthKey \"$key\" -HeadscaleUrl \"${HEADSCALE_URL:-}\" -Only tailscale"
}

tailscale_key() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env"
    return 1
  fi
  if [[ -z "${HEADSCALE_URL:-}" ]]; then
    echo >&2 "  ⚠  HEADSCALE_URL not set in .env"
    return 1
  fi
  echo "tailscale up --login-server ${HEADSCALE_URL} --auth-key $key --unattended --timeout 30s"
}

new_tailscale_key() {
  echo >&2 "  Generating new key via headscale..."
  local key
  # 2160h = 90 days, so onboarding keys don't silently expire mid-rollout.
  key=$(ssh headscale 'docker exec headscale headscale preauthkeys create --user 1 --reusable --expiration 2160h' 2>/dev/null)
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  Failed to generate key (SSH to headscale failed?)"
    return 1
  fi
  # Update .env
  if grep -q '^TAILSCALE_AUTH_KEY=' "$SCRIPT_DIR/.env" 2>/dev/null; then
    sed -i '' "s|^TAILSCALE_AUTH_KEY=.*|TAILSCALE_AUTH_KEY=$key|" "$SCRIPT_DIR/.env"
  else
    echo "TAILSCALE_AUTH_KEY=$key" >> "$SCRIPT_DIR/.env"
  fi
  # No effect on parent (we run in $(...) subshell), but documents intent.
  # Visibility to other menu options happens via the .env re-source in the loop.
  export TAILSCALE_AUTH_KEY="$key"
  echo >&2 "  Saved new key to .env (expires in 90 days)"
  echo "$key"
}

# ---------------------------------------------------------------------------
# Server monitoring (sage-* always-on servers): Tailscale watchdog + Better
# Stack heartbeat (+ Vector host_metrics).  See docs/runbooks/server-monitoring.md
# ---------------------------------------------------------------------------

# Map a server name to its VECTOR_SOURCE_TOKEN_<HOST> .env variable name.
_vector_token_var() { echo "VECTOR_SOURCE_TOKEN_$(printf '%s' "$1" | tr 'a-z-' 'A-Z_')"; }
# Map a server name to its VECTOR_SOURCE_INGEST_<HOST> .env variable name.
_vector_ingest_var() { echo "VECTOR_SOURCE_INGEST_$(printf '%s' "$1" | tr 'a-z-' 'A-Z_')"; }
# Map a server name to its TAILNET_ANCHORS_<HOST> .env variable name.
_anchors_var() { echo "TAILNET_ANCHORS_$(printf '%s' "$1" | tr 'a-z-' 'A-Z_')"; }
# Space-separated server lists from .env (topology kept out of this public repo).
_servers() { echo "${SERVERS_MONITORED:-}"; }              # Windows sage-* servers
_linux_servers() { echo "${LINUX_SERVERS_MONITORED:-}"; }  # Linux droplets (native Vector)

# Upsert KEY=VALUE in .env (replace in place or append).
_env_set() {
  local var="$1" val="$2"
  if grep -q "^${var}=" "$SCRIPT_DIR/.env" 2>/dev/null; then
    sed -i '' "s|^${var}=.*|${var}=${val}|" "$SCRIPT_DIR/.env"
  else
    echo "${var}=${val}" >> "$SCRIPT_DIR/.env"
  fi
}

# Create (or reuse) the "<name>" vector telemetry source. Echoes "token<TAB>ingest_host"
# on stdout; diagnostics go to stderr. Needs the TELEMETRY API token (distinct
# from the uptime token used for heartbeats/incidents).
_ensure_vector_source() {
  local name="$1"
  local tel="${BETTERSTACK_TELEMETRY_TOKEN:-}"
  if [[ -z "$tel" ]]; then
    echo >&2 "  ⚠  BETTERSTACK_TELEMETRY_TOKEN not set in .env (Better Stack → Telemetry → Settings → API tokens)"
    return 1
  fi
  echo >&2 "  Looking up existing source '$name'..."
  local list token ingest
  list=$(curl -fsS -H "Authorization: Bearer $tel" "https://telemetry.betterstack.com/api/v1/sources?per_page=250" 2>/dev/null) || {
    echo >&2 "  ⚠  Could not list telemetry sources (check BETTERSTACK_TELEMETRY_TOKEN)"; return 1; }
  token=$(printf '%s' "$list" | jq -r --arg n "$name" '.data[]? | select(.attributes.name==$n) | .attributes.token' | head -1)
  ingest=$(printf '%s' "$list" | jq -r --arg n "$name" '.data[]? | select(.attributes.name==$n) | .attributes.ingesting_host' | head -1)

  if [[ -n "$token" && "$token" != "null" ]]; then
    echo >&2 "  ✓ Reusing existing source '$name'"
  else
    echo >&2 "  Creating source '$name' (vector, us_east, 90d logs+metrics)..."
    local resp
    resp=$(curl -fsS -X POST "https://telemetry.betterstack.com/api/v1/sources" \
      -H "Authorization: Bearer $tel" -H 'Content-Type: application/json' \
      -d "$(jq -nc --arg n "$name" '{name:$n,platform:"vector",data_region:"us_east",logs_retention:90,metrics_retention:90}')") || {
        echo >&2 "  ⚠  Source creation failed"; return 1; }
    token=$(printf '%s' "$resp" | jq -r '(.data.attributes.token // .attributes.token) // empty')
    ingest=$(printf '%s' "$resp" | jq -r '(.data.attributes.ingesting_host // .attributes.ingesting_host) // empty')
  fi
  if [[ -z "$token" || "$token" == "null" ]]; then echo >&2 "  ⚠  Could not obtain source token from the API response"; return 1; fi
  printf '%s\t%s\n' "$token" "$ingest"
}

# Provision a Vector source for a Windows sage-* server and save its token to .env.
provision_vector_source() {
  local server
  if [[ -z "$(_servers)" ]]; then echo >&2 "  ⚠  SERVERS_MONITORED not set in .env"; return 1; fi
  # shellcheck disable=SC2046  # intentional word-split of the space-separated server list
  server=$(gum choose $(_servers) --header "Provision Better Stack Vector source for which server?" </dev/tty) || return 1
  [[ -z "$server" ]] && return 1

  local out token ingest; out=$(_ensure_vector_source "$server (Vector)") || return 1
  token=${out%%$'\t'*}; ingest=${out#*$'\t'}
  local tvar ivar; tvar=$(_vector_token_var "$server"); ivar=$(_vector_ingest_var "$server")
  _env_set "$tvar" "$token"
  _env_set "$ivar" "$ingest"
  echo >&2 "  Saved $tvar + $ivar to .env"
  echo "$token"
}

# Provision the SINGLE shared "Host metrics (Vector)" source that all Linux hosts
# ship to (host= tag distinguishes them), and save its token + ingest host to
# .env. Idempotent: reuses the existing shared source.
provision_linux_vector_source() {
  local out token ingest; out=$(_ensure_vector_source "Host metrics (Vector)") || return 1
  token=${out%%$'\t'*}; ingest=${out#*$'\t'}
  _env_set "VECTOR_SHARED_SOURCE_TOKEN" "$token"
  _env_set "VECTOR_SHARED_SOURCE_INGEST" "$ingest"
  echo >&2 "  Saved VECTOR_SHARED_SOURCE_TOKEN + VECTOR_SHARED_SOURCE_INGEST to .env"
  echo "$token"
}

# Emit the remote bash one-liner that installs native Vector host_metrics on a
# Linux host, shipping to the shared source tagged host=<server> (no Docker, no
# eBPF -- see scripts/install-vector-host-metrics.sh).
install_linux_host_metrics() {
  local server
  if [[ -z "$(_linux_servers)" ]]; then echo >&2 "  ⚠  LINUX_SERVERS_MONITORED not set in .env"; return 1; fi
  # shellcheck disable=SC2046  # intentional word-split of the space-separated server list
  server=$(gum choose $(_linux_servers) --header "Install Vector host metrics on which Linux host?" </dev/tty) || return 1
  [[ -z "$server" ]] && return 1

  local tok="${VECTOR_SHARED_SOURCE_TOKEN:-}" ingest="${VECTOR_SHARED_SOURCE_INGEST:-}"
  if [[ -z "$tok" || -z "$ingest" ]]; then
    echo >&2 "  ⚠  VECTOR_SHARED_SOURCE_TOKEN / _INGEST not set — run 'provision Linux Vector source' first"; return 1
  fi
  echo "curl -fsSL https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/install-vector-host-metrics.sh | sudo bash -s -- --source-token \"$tok\" --ingest-host \"$ingest\" --host-name \"$server\""
}

# Emit the remote PowerShell one-liner that installs the watchdog + heartbeat
# (and bundles Vector host_metrics on sage-iai/sage-server when a source token
# is present). Uptime token is required; Vector token is optional.
install_server_monitoring() {
  local server
  if [[ -z "$(_servers)" ]]; then echo >&2 "  ⚠  SERVERS_MONITORED not set in .env"; return 1; fi
  # shellcheck disable=SC2046  # intentional word-split of the space-separated server list
  server=$(gum choose $(_servers) --header "Install watchdog + heartbeat (+ Vector) on which server?" </dev/tty) || return 1
  [[ -z "$server" ]] && return 1

  local up="${BETTERSTACK_UPTIME_TOKEN:-}"
  if [[ -z "$up" ]]; then
    echo >&2 "  ⚠  BETTERSTACK_UPTIME_TOKEN not set in .env — using placeholder"
    up="<paste-uptime-token-here>"
  fi

  local avar anchors; avar=$(_anchors_var "$server"); anchors="${!avar:-}"
  if [[ -z "$anchors" ]]; then echo >&2 "  ⚠  $avar not set in .env — cannot supply watchdog anchors"; return 1; fi

  local var vtok ivar vingest
  var=$(_vector_token_var "$server"); vtok="${!var:-}"
  ivar=$(_vector_ingest_var "$server"); vingest="${!ivar:-}"
  local cmd="Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/install-tailscale-watchdog.ps1 -OutFile \$env:TEMP\\install-tailscale-watchdog.ps1; & \$env:TEMP\\install-tailscale-watchdog.ps1 -Server ${server} -Anchors ${anchors} -BetterStackApiToken \"$up\""
  if [[ -n "$vtok" && -n "$vingest" ]]; then
    cmd="$cmd -VectorSourceToken \"$vtok\" -VectorIngestHost \"$vingest\""
  else
    cmd="$cmd -SkipVector"
    if [[ -z "$vtok" ]]; then
      echo >&2 "  ⚠  $var not set — emitting -SkipVector (run 'provision Vector source' first for host metrics)"
    else
      echo >&2 "  ⚠  $ivar not set — emitting -SkipVector (re-run 'provision Vector source' to cache the ingest host)"
    fi
  fi
  echo "$cmd"
}

# ---------------------------------------------------------------------------
# Menu
# ---------------------------------------------------------------------------

LABELS=(
  "Set up workstation (apps + Tailscale + Zoiper)"
  "GCPW — new machine setup"
  "GCPW — reset user state (re-test first login)..."
  "Zoiper — install + configure..."
  "Tailscale — install + join (only)"
  "Tailscale — join network (from .env)"
  "Generate new Tailscale key (SSH → headscale, saves to .env)..."
  "sage-amg — onboard new user..."
  "Server monitoring — install watchdog + heartbeat (+ Vector) on a sage-* server..."
  "Server monitoring — provision Better Stack Vector source (saves token to .env)..."
  "Server monitoring — provision shared Vector source for Linux hosts (saves token + ingest to .env)..."
  "Server monitoring — install Vector host metrics on a Linux host..."
  "JumpCloud to GCPW — phase 1..."
  "JumpCloud to GCPW — phase 2"
)

# Map label → function
dispatch() {
  case "$1" in
    "GCPW — new machine setup")                 new_machine ;;
    "GCPW — reset user state (re-test first login)...") reset_gcpw_user ;;
    "Set up workstation (apps + Tailscale + Zoiper)") install_apps ;;
    "Tailscale — install + join (only)")        install_tailscale ;;
    "Zoiper — install + configure...")             zoiper_setup ;;
    "sage-amg — onboard new user...")           sage_amg_onboard ;;
    "Server monitoring — install watchdog + heartbeat (+ Vector) on a sage-* server...") install_server_monitoring ;;
    "Server monitoring — provision Better Stack Vector source (saves token to .env)...") provision_vector_source ;;
    "Server monitoring — provision shared Vector source for Linux hosts (saves token + ingest to .env)...") provision_linux_vector_source ;;
    "Server monitoring — install Vector host metrics on a Linux host...") install_linux_host_metrics ;;
    "JumpCloud to GCPW — phase 1...")              migration_phase1 ;;
    "JumpCloud to GCPW — phase 2")               migration_phase2 ;;
    "Tailscale — join network (from .env)")            tailscale_key ;;
    "Generate new Tailscale key (SSH → headscale, saves to .env)...") new_tailscale_key ;;
    *) return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# Loop
# ---------------------------------------------------------------------------

PS3="  Pick an option (q to quit): "
echo
select choice in "${LABELS[@]}"; do
  [[ -z "$choice" ]] && { [[ "$REPLY" == q ]] && break; continue; }

  # Re-load .env each iteration so option-9 (key rotation) is visible to option 8.
  load_env

  payload=$(dispatch "$choice") || { echo; continue; }

  printf '%s' "$payload" | pbcopy
  gum style --foreground 35 "  ✓ Copied: $choice"
  echo
done
