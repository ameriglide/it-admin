#!/usr/bin/env bash
#
# Interactive clipboard helper for workstation setup.
# Copies one-liners and secrets to the clipboard so you can paste them
# into a remote machine's PowerShell prompt.
#
# Usage: ./bin/copy
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Load .env if present
if [[ -f "$SCRIPT_DIR/.env" ]]; then
  # shellcheck disable=SC2046
  export $(grep -v '^#' "$SCRIPT_DIR/.env" | xargs)
fi

# ---------------------------------------------------------------------------
# Menu entries: label → payload (computed lazily via functions)
# ---------------------------------------------------------------------------

new_machine() {
  echo 'Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/deploy-gcpw.ps1 -OutFile $env:TEMP\deploy-gcpw.ps1; & $env:TEMP\deploy-gcpw.ps1 -NewMachine -Domain ameriglide.com'
}

repair_gcpw() {
  echo 'Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/repair-gcpw.ps1 -OutFile $env:TEMP\repair-gcpw.ps1; & $env:TEMP\repair-gcpw.ps1 -Domain ameriglide.com'
}

install_apps() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env — using placeholder"
    key="<paste-key-here>"
  fi
  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/install-apps.ps1 -OutFile \$env:TEMP\\install-apps.ps1; & \$env:TEMP\\install-apps.ps1 -TailscaleAuthKey \"$key\""
}

migration_phase1() {
  local user
  user=$(gum input --placeholder "Google username (e.g. jsmith)" --header "Migration: enter employee username")
  [[ -z "$user" ]] && return 1
  echo "Set-ExecutionPolicy Bypass -Scope Process -Force; irm https://raw.githubusercontent.com/ameriglide/it-admin/main/scripts/deploy-gcpw.ps1 -OutFile \$env:TEMP\\deploy-gcpw.ps1; & \$env:TEMP\\deploy-gcpw.ps1 -GoogleEmail ${user}@ameriglide.com -Domain ameriglide.com -WindowsUsername ${user} -Phase 1"
}

migration_phase2() {
  echo '& $env:TEMP\deploy-gcpw.ps1 -Phase 2'
}

tailscale_key() {
  local key="${TAILSCALE_AUTH_KEY:-}"
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  TAILSCALE_AUTH_KEY not set in .env"
    return 1
  fi
  echo "$key"
}

new_tailscale_key() {
  echo >&2 "  Generating new key via headscale..."
  local key
  key=$(ssh headscale 'docker exec headscale headscale preauthkeys create --user 1 --expiration 24h' 2>/dev/null)
  if [[ -z "$key" ]]; then
    echo >&2 "  ⚠  Failed to generate key (SSH to headscale failed?)"
    return 1
  fi
  # Update .env
  if grep -q '^TAILSCALE_AUTH_KEY=' "$SCRIPT_DIR/.env" 2>/dev/null; then
    sed -i '' "s|^TAILSCALE_AUTH_KEY=.*|TAILSCALE_AUTH_KEY=$key|" "$SCRIPT_DIR/.env"
  else
    echo "TAILSCALE_AUTH_KEY=$key" >> "$SCRIPT_DIR/.env"
  fi
  export TAILSCALE_AUTH_KEY="$key"
  echo >&2 "  Updated .env with new key (expires in 24h)"
  echo "$key"
}

# ---------------------------------------------------------------------------
# Menu
# ---------------------------------------------------------------------------

LABELS=(
  "GCPW — new machine setup"
  "GCPW — repair (tile not showing)"
  "Install apps (with Tailscale key)"
  "GCPW — migration phase 1..."
  "GCPW — migration phase 2"
  "Tailscale auth key (from .env)"
  "Generate new Tailscale key (SSH → headscale)..."
)

# Map label → function
dispatch() {
  case "$1" in
    "GCPW — new machine setup")                 new_machine ;;
    "GCPW — repair (tile not showing)")         repair_gcpw ;;
    "Install apps (with Tailscale key)")        install_apps ;;
    "GCPW — migration phase 1...")               migration_phase1 ;;
    "GCPW — migration phase 2")                 migration_phase2 ;;
    "Tailscale auth key (from .env)")            tailscale_key ;;
    "Generate new Tailscale key (SSH → headscale)...") new_tailscale_key ;;
    *) return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# Loop
# ---------------------------------------------------------------------------

while true; do
  echo
  choice=$(gum choose "${LABELS[@]}" \
    --header "  Copy to clipboard (esc to quit)" \
    --header.foreground 240 \
    --cursor.foreground 33 \
    --selected.foreground 33) || break

  payload=$(dispatch "$choice") || continue

  printf '%s' "$payload" | pbcopy
  gum style --foreground 35 "  ✓ Copied: $choice"

  # Wait for keypress before showing menu again; esc exits
  read -rsn1 -p "  Press any key to copy another, or Esc to quit... " key </dev/tty
  echo
  [[ "$key" == $'\e' ]] && break
done
