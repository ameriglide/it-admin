#!/usr/bin/env bash
#
# Rotate the AWS SSM hybrid activation.
#
# SSM hybrid activations expire after at most 30 days (AWS hard limit), so the
# activation baked into workstation onboarding (setup-workstation.ps1 -Only ssm,
# and the full "Set up workstation" run) must be refreshed ~monthly or new boxes
# will install the agent but fail to register.
#
# This mints a fresh activation, rewrites SSM_ACTIVATION_ID/CODE in this checkout's
# .env and in any peer .env files (SSM_ROTATE_PEERS), then deletes the previous
# activation. Already-registered instances are unaffected by the old one's deletion.
#
# Usage: ./bin/rotate-ssm-activation
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"
[[ -f "$ENV_FILE" ]] || { echo "no .env at $ENV_FILE" >&2; exit 1; }

set -a
# shellcheck disable=SC1090
. "$ENV_FILE"
set +a

PROFILE="${SSM_ROTATE_PROFILE:-ag-aws-admin}"   # AWS CLI profile with create/delete-activation
ROLE="${SSM_ROTATE_ROLE:-ssm-hybrid-role}"      # IAM role trusting ssm.amazonaws.com
REGION="${SSM_REGION:-us-east-1}"
LIMIT="${SSM_ROTATE_LIMIT:-100}"
OLD_ID="${SSM_ACTIVATION_ID:-}"

# Max 30-day expiry (GNU date fallback for non-macOS schedulers).
EXP=$(date -u -v+30d '+%Y-%m-%dT%H:%M:%S' 2>/dev/null || date -u -d '+30 days' '+%Y-%m-%dT%H:%M:%S')

echo "Minting new SSM activation (role=$ROLE, limit=$LIMIT, region=$REGION)..."
JSON=$(aws ssm create-activation --profile "$PROFILE" --region "$REGION" \
  --iam-role "$ROLE" --registration-limit "$LIMIT" --expiration-date "$EXP" \
  --default-instance-name amg-workstation \
  --description "AmeriGlide workstations (rotated $(date -u +%Y-%m-%d))" --output json)
NID=$(printf '%s' "$JSON" | jq -r '.ActivationId // empty')
NCODE=$(printf '%s' "$JSON" | jq -r '.ActivationCode // empty')
[[ -n "$NID" && -n "$NCODE" ]] || { echo "mint failed: $JSON" >&2; exit 1; }
echo "  new activation $NID (expires $EXP)"

# Rewrite SSM_ACTIVATION_ID/CODE in one .env (local path, or user@host:/path over ssh).
# Brace-delimited perl so the base64 code's '/' chars don't clash.
_update_env() {
  local target="$1"
  local prog="s{^SSM_ACTIVATION_ID=.*}{SSM_ACTIVATION_ID='$NID'}; s{^SSM_ACTIVATION_CODE=.*}{SSM_ACTIVATION_CODE='$NCODE'}"
  if [[ "$target" == *:* ]]; then
    local hp="${target%%:*}" path="${target#*:}" user host
    user="${hp%@*}"; host="${hp#*@}"
    ssh -o ConnectTimeout=15 "$host" "sudo -nH -u $user perl -i -pe \"$prog\" '$path'"
  else
    perl -i -pe "$prog" "$target"
  fi
}

echo "Updating .env files..."
_update_env "$ENV_FILE" && echo "  updated $ENV_FILE"
# shellcheck disable=SC2086  # intentional word-split of the space-separated peer list
for peer in ${SSM_ROTATE_PEERS:-}; do
  if _update_env "$peer"; then echo "  updated $peer"; else echo "  WARN: could not update $peer (rotate it manually)" >&2; fi
done

# Delete the previous activation (registered mi- instances keep working).
if [[ -n "$OLD_ID" && "$OLD_ID" != "$NID" ]]; then
  aws ssm delete-activation --profile "$PROFILE" --region "$REGION" --activation-id "$OLD_ID" \
    && echo "Deleted previous activation $OLD_ID"
fi
echo "Done."
